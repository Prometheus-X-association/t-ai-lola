{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Terms of use - {% trans %}dashboard.termsofuse.new.title{% endtrans %} {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-database fa-2x sidebar-brand-icon"></i> 
            <span class="text-monospace sidebar-brand-text ml-4 mt-1">{% trans %}dashboard.termsofuse.new.creation_termsofuse{% endtrans %}</span>
        </div>
        <a href="{{ path('dashboard_termsofuse_index') }}" class="btn btn-sm btn-primary">
            <i class="fas fa-arrow-left"></i>
            {% trans %}dashboard.termsofuse.new.btn_retour{% endtrans %}
        </a>
    </div>

    <div class="row">
        <div class="col-8">
            {{ include('dashboard/termsofuse/_form.html.twig', {'button_label': 'dashboard.termsofuse.new.btn_ajouter'|trans}) }}
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> {% trans %}dashboard.termsofuse.new.aide_titre{% endtrans %}
                </div>
                <div class="card-body">
                    {% trans %}dashboard.termsofuse.new.aide{% endtrans %}
                </div>
            </div>                
        </div>
    </div>

{% endblock %}
