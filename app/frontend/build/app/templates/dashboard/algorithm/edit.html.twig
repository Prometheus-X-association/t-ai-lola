{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Algorithme - Modification {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-code fa-2x sidebar-brand-icon"></i> 
            <span class="text-monospace sidebar-brand-text ml-4 mt-1">Modification de l'algorithme <strong>{{ algorithm.name }}</strong></span>
        </div>
        <a href="{{ path('dashboard_algorithm_index') }}" class="btn btn-sm btn-primary">
            <i class="fas fa-arrow-left"></i>
            Retour à la liste des algorithmes
        </a>
    </div>

    <div class="row">
        <div class="col-8">
            {{ include('dashboard/algorithm/_form.html.twig', {'button_label': 'Modifier'}) }}
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Algorithme
                </div>
                <div class="card-body">
                    <h5 class="card-title">Modification d'un algorithme</h5>
                    <p class="card-text">
                        Lorem Ipsum on lihtsalt proovitekst, mida kasutatakse printimis- ja ladumistööstuses. 
                        See on olnud tööstuse põhiline proovitekst juba alates 1500. aastatest, mil tundmatu 
                        printija võttis hulga suvalist teksti, et teha trükinäidist. Lorem Ipsum ei ole ainult
                        viis sajandit säilinud, vaid on ka edasi kandunud elektroonilisse trükiladumisse, jäädes
                        sealjuures peaaegu muutumatuks. See sai tuntuks 1960. aastatel Letraset'i lehtede 
                        väljalaskmisega, ja hiljuti tekstiredaktoritega nagu Aldus PageMaker, mis sisaldavad 
                        erinevaid Lorem Ipsumi versioone.
                    </p>
                </div>
            </div>            
        </div>
    </div>

{% endblock %}
