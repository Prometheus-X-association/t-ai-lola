{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Algorithme - Edit {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-code fa-2x sidebar-brand-icon"></i> 
            <span class="text-monospace sidebar-brand-text ml-4 mt-1">Edit algorithm <strong>{{ algorithm.name }}</strong></span>
        </div>
        <a href="{{ path('dashboard_algorithm_index') }}" class="btn btn-sm btn-primary">
            <i class="fas fa-arrow-left"></i>
            Back to algorithm list
        </a>
    </div>

    <div class="row">
        <div class="col-8">
            {{ include('dashboard/algorithm/_form.html.twig', {'button_label': 'Update'}) }}
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Algorithm
                </div>
                <div class="card-body">
                    <h5 class="card-title">Editing an algorithm</h5>
                    <p class="card-text">
                        This page allows you to update the main information of an algorithm.
                        You can edit its title, repository URL, description and visibility.
                    </p>
                    <p class="card-text">
                        The description should briefly explain what the algorithm does,
                        what it is used for, and any useful information for users who may
                        need to run it or include it in a scenario.
                    </p>
                    <p class="card-text">
                        If the algorithm is visible to other users, they will be able to see
                        it in the application and use it according to their access rights.
                    </p>
                </div>
            </div>            
        </div>
    </div>

{% endblock %}
