{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Algorithms {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-code fa-2x sidebar-brand-icon"></i>
            <span class="text-monospace sidebar-brand-text ml-4 mt-1"> Algorithm administration</span>
        </div>
        <span class="float-right">
            <a href="{{ path('dashboard_algorithm_new') }}" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i>
                Add an algorithm
            </a>
        </span>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered dt-basic" id="table_algorithms" width="98%" cellspacing="0">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Version</th>
                    <th scope="col">Creation date</th>
                    <th scope="col">Last update</th>
                    <th scope="col">&nbsp;</th>
                </tr>
            </thead>
            <tbody>
                {% for algorithm in algorithms %}
                    <tr>                        
                        <td>
                            {{ algorithm.name }} <span class="badge badge-primary badge-pill float-right">{{ algorithm.isPublic ? 'Public' : 'Private'}}</span>
                            {% if algorithm.urlRepository %}
                                <hr />
                                <a href="{{ algorithm.urlRepositoryNoToken }}" target="_blank">
                                    {{ algorithm.urlRepositoryNoToken }} <i class="fas fa-external-link-alt"> </i>
                                </a>
                            {% endif %}
                        </td>
                        <td>
                            {% for algorithmVersion in algorithm.algorithmVersions %}
                                {% if algorithmVersion.status == constant('\\App\\Entity\\AlgorithmVersion::STATUS_PROCESSING') %}
                                    <a href="#" data-toggle="modal" data-target="#modal_suppression_version1{{ algorithmVersion.hash }}" title="This version is currently being created. Click for more information." class="text-warning">
                                        <i class="fas fa-info-circle"> </i>
                                        {{ algorithmVersion.name }}
                                    </a>
                                {% elseif algorithmVersion.status == constant('\\App\\Entity\\AlgorithmVersion::STATUS_ERROR') %}
                                    <a href="#" data-toggle="modal" data-target="#modal_suppression_version2{{ algorithmVersion.hash }}" title="This version has an error. Click for more information." class="text-danger">
                                        <i class="fas fa-times-circle"> </i>
                                        {{ algorithmVersion.name }}
                                    </a>
                                {% elseif algorithmVersion.status == constant('\\App\\Entity\\AlgorithmVersion::STATUS_AVAILABLE') %}
                                    <a class="text-success" role="button" data-toggle="tooltip" data-placement="right" title="This version is available.">
                                        <i class="fas fa-info-circle"> </i>
                                        {{ algorithmVersion.name }}
                                    </a>
                                {% endif %}
                                <br />
                            {% endfor %}
                        </td>                        
                        <td>
                            {% if algorithm.createdBy is not null and algorithm.createdAt is not null%}
                                {{ algorithm.createdAt | date('d-m-Y H:i:s') }}
                                <br /><i>({{ algorithm.createdBy }})</i>
                            {% else %}
                                <i>not defined</i>
                            {% endif %}
                        </td>
                        <td>
                            {% if algorithm.updatedBy is not null and algorithm.updatedAt is not null%}
                                {{ algorithm.updatedAt | date('d-m-Y H:i:s') }}
                                <br /><i>({{ algorithm.updatedBy }})</i>
                            {% else %}
                                <i>not defined</i>
                            {% endif %}
                        </td>
                        <td>
                            <form method="post" class="form" action="{{ path('dashboard_algorithm_delete', {'id': algorithm.id}) }}">
                                <input type="hidden" name="_method" value="DELETE">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ algorithm.id) }}">
                                <a class="btn btn-outline-primary btn-sm" href="{{ path('dashboard_algorithm_edit', {'id': algorithm.id}) }}">
                                    <i class="fa fa-edit"></i> Edit
                                </a>
                                <a class="btn btn-outline-dark btn-sm" href="#" data-toggle="modal" data-target="#modal_tag_{{algorithm.id}}">
                                    <i class="fas fa-tags"></i> Add version
                                </a>
                                <hr />                                    
                                {%  if algorithm.isPublic %}
                                    <a href="{{ path("dashboard_algorithm_toggle_public", {'id': algorithm.id}) }}" class="btn btn-danger btn-sm">
                                        <i class="fas fa-lock"></i> Make private
                                    </a>
                                {% else %}
                                    <a href="{{ path("dashboard_algorithm_toggle_public", {'id': algorithm.id}) }}" class="btn btn-success btn-sm">
                                        <i class="fas fa-lock-open"></i> Make visible to users
                                    </a>
                                {% endif %}
                                </a>
                            </form>
                        </td>
                    </tr>

                    <!-- modal création version -->
                <div class="modal fade" tabindex="-1" role="dialog" id="modal_tag_{{algorithm.id}}">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h4 class="modal-title">
                                    <em>{{ algorithm.name }}</em>
                                    <footer class="blockquote-footer">Add a version</footer>
                                </h4>

                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <form action="{{ path("dashboard_algorithm_version_new") }}" method="POST">
                                    <input type="hidden" name="algorithm_id" value="{{ algorithm.id }}" />
                                    <label for="name" class="font-weight-bold">Version name</label>
                                    <input type="text" id="name" name="version_name" class="form-control" aria-describedby="versionHelpBlock">
                                    <small id="versionHelpBlock" class="form-text text-muted">
                                        Enter the name of the version to create. This can be a Git branch, tag or release name, depending on how the algorithm repository is managed.
                                    </small>
                                    <hr />
                                    <button type="submit" class="btn btn-success btn-block">Add version</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- modal création version -->

                <!-- modal suppression version en PROCESSING-->
                {% for algorithmVersion in algorithm.algorithmVersions %}
                <div class="modal fade" tabindex="-1" role="dialog" id="modal_suppression_version1{{ algorithmVersion.hash }}">
                        <div class="modal-dialog modal-dialog-scrollable" role="document">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        Delete version
                                        <strong style="color:#0099cc;"><em>{{ algorithmVersion.name }}</strong></em><br>
                                        from algorithm
                                        <strong style="color:#0099cc;"><em>{{ algorithmVersion.algorithm.name  }}</strong></em> 
                                    </h5>                                    
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                 <div class="modal-body">
                                    <div class="col-12" style="font-size:18px;">
                                        This version is currently being created. You can delete it if the process is blocked or no longer needed.
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button onclick="window.location.href = '{{ path("dashboard_algorithm_version_delete", {'hash': algorithmVersion.hash}) }}';" type="button" class="btn btn-danger" data-dismiss="modal">Confirm</button>
                                    <button type="button" class="btn btn-primary" data-dismiss="modal">Cancel</button>
                                </div>
                            </div>
                        </div>
                </div>
                    {% endfor %}
                <!-- modal suppression version en PROCESSING -->

                <!-- modal suppression version en ERROR -->
                {% for algorithmVersion in algorithm.algorithmVersions %}
                <div class="modal fade" tabindex="-1" role="dialog" id="modal_suppression_version2{{ algorithmVersion.hash }}">
                        <div class="modal-dialog modal-dialog-scrollable" role="document">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        Delete version
                                        <strong style="color:#0099cc;"><em>{{ algorithmVersion.name }}</strong></em><br>
                                        from algorithm
                                        <strong style="color:#0099cc;"><em>{{ algorithmVersion.algorithm.name  }}</strong></em> 
                                    </h5>                                    
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="col-12" style="font-size:18px;">
                                        {% if  algorithmVersion.log  %}
                                            <em>"{{ algorithmVersion.log }}"<em><br>
                                        {% endif %}
                                        This version could not be created correctly. You can delete it and try to add it again after fixing the problem.<br>  
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button onclick="window.location.href = '{{ path("dashboard_algorithm_version_delete", {'hash': algorithmVersion.hash}) }}';" type="button" class="btn btn-danger" data-dismiss="modal">Confirm</button>
                                    <button type="button" class="btn btn-primary" data-dismiss="modal">Cancel</button>
                                </div>
                            </div>
                        </div>
                </div>
                    {% endfor %}
                <!-- modal suppression version en ERROR -->

            {% else %}
                <tr>
                    <td colspan="5"><em>No algorithm found</em></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
