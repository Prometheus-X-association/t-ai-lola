{% extends "dashboard/base/base.html.twig" %}

{% block title %}Accueil{% endblock %}

{% block body %}

    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Left menu -->
        {{ include("dashboard/base/left_menu.html.twig") }}

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Navbar -->
                {{ include("dashboard/base/navbar.html.twig") }}

                <!-- Flash message -->
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success ml-4 mr-4">
                        {{ message }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger ml-4 mr-4">
                        {{ message }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="alert alert-warning ml-4 mr-4">
                        {{ message }}
                    </div>
                {% endfor %}                
                
                <!-- Begin Page Content -->
                <div class="container-fluid">
                    {% block content %}{% endblock %}
                </div>
                <!-- /.container-fluid -->

            </div><!-- Main Content -->

            <!-- Footer -->
            {{ include("dashboard/base/footer.html.twig") }}

        </div><!-- Content Wrapper -->

    </div><!-- Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

{% endblock %}   

