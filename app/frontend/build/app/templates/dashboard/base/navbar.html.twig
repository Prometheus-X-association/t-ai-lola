            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-danger btn btn-sm" title="Se déconnecter" href="{{ path('app_logout') }}">
                <b>{% trans %}dashboard.navbar.deconnexion{% endtrans %} <i class="red fas fa-sign-out-alt"> </i></b>
            </a>
        </li>

    </ul>

</nav>
