<!-- Topbar -->
<nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">

    <!-- Sidebar Toggle (Topbar) -->
    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
        <i class="fa fa-bars"></i>
    </button>

    {% if not lolapy.isLolapyReady() %}
        <div class="alert alert-warning mb-0">
            <i class="fas fa-exclamation-triangle"> </i> 
            {% trans %}dashboard.navbar.lolapy_inaccessible{% endtrans %}
        </div>
    {% endif %}

    <!-- Topbar Navbar -->
    <ul class="navbar-nav ml-auto">

        {% if app.user.groups|length > 0 %}
            <!-- Groups -->

            <li class="nav-item">
                <a class="nav-link">
                    <span class="text-gray-600 mr-2">
                        <strong>{% trans %}dashboard.navbar.groupes{% endtrans %}</strong>  
                    </span> 
                    <span class="text-primary">
                        {% for group in app.user.groups %}
                            <span class="badge badge-info">{{ group.name }}</span>
                        {% endfor %}
                    </span>
                </a>
            </li> 
        {% endif %}

        <div class="topbar-divider d-none d-sm-block"></div>

        <!-- User Information -->
        <li class="nav-item">
            <a class="nav-link">
                <span class="text-gray-600">
                    <strong>{{ app.user.firstname }} {{ app.user.lastname }}</strong> - 
                    <span class="text-primary"><em>{{ app.user.roles|map(role => app.user.getRole(role))|join(', ', '') }}</em></span>
                </span>
            </a>
        </li> 
        <div class="topbar-divider d-none d-sm-block"></div>

        <!-- Lolapy Information -->
        <li class="nav-item">
            {% if app_env == "dev" %}
                {% set lolapyParameters = lolapy.getLolapyParameters() %}
                <a class="nav-link" href="#"
                   data-container="body" 
                   data-toggle="popover" 
                   data-placement="bottom" 
                   title="<strong>Lolapy configuration</strong>" 
                   data-content="<strong>IP</strong> : {{ lolapyParameters["LOLAPY_API_ADRESS"] }} <br /> <strong>Port</strong> : {{ lolapyParameters["LOLAPY_API_PORT"] }} <br /> <strong>Fake</strong> : {{ lolapyParameters["LOLAPY_API_FAKE"] }} <br /> ">
                    {{ lolapy.isLolapyReady() ? "<span class='text-success font-weight-bold'> Lolapy <i class='fas fa-power-off'> </i></span>" : "<span class=''> Lolapy <i class='fas fa-power-off'> </i></span>"}}
                </a>
            {% else %}
                <a class="nav-link" href="#">
                    {{ lolapy.isLolapyReady() ? "<span class='text-success font-weight-bold'> Lolapy <i class='fas fa-power-off'> </i></span>" : "<span class=''> Lolapy <i class='fas fa-power-off'> </i></span>"}}
                </a>
            {% endif %}
        </li>
        
        <div class="topbar-divider d-none d-sm-block"></div>
        
        <!-- Run en cours -->
{#        <li class="nav-item dropdown no-arrow">
            <a class="nav-link dropdown-toggle text-gray-600" href="#" id="alertsDropdown" role="button"
               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
