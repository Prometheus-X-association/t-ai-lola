{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Lolapy Logs {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-list fa-2x sidebar-brand-icon"></i> 
            <span class="text-monospace sidebar-brand-text ml-4 mt-1"> Consultation des logs de l'api Lola (Lolapy)</span>
        </div>
        <a href="{{ path('app.swagger_ui') }}" target="_blank" class="btn btn-sm btn-primary">
            Frontend API Documentation 
            <i class="fas fa-external-link-alt ml-2"> </i> 
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered dt-basic" id="table_apilog" width="98%" cellspacing="0">
            <thead>
                <tr>
                    <th scope="col">Datetime</th>
                    <th scope="col">Type</th>
                    <th scope="col">Message</th>
                    <th scope="col">Détails</th>
                </tr>
            </thead>
            <tbody>
                {% for apilog in apilogs %}
                    <tr>
                        <td data-sort="{{ apilog.datetime|date('U') }}">{{ apilog.datetime | date('d-m-Y H:i:s')  }}</td>
                        <td>{{ apilog.type }}</td>
                        <td>{{ apilog.message }}</td>
                        <td>{{ apilog.details }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4"><em>Aucun log</em></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
