{% extends "dashboard/base/layout.html.twig" %}
{% block title %} {% trans %}dashboard.scenario.creation_etape2.titre{% endtrans %} {% endblock %}

{% block content %}
    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-database fa-2x sidebar-brand-icon"></i>
            <span class="text-monospace sidebar-brand-text ml-4 mt-1">{% trans %}dashboard.scenario.creation_etape2.titre{% endtrans %}</span>
        </div>
        <span class="float-right">
            <a class="btn btn-sm btn-primary" href="{{ path("dashboard_scenario_index") }}">
                <i class="fas fa-cogs"></i>
                {% trans %}dashboard.scenario.creation_etape2.btn_retour_scenario{% endtrans %}
            </a>
        </span>
    </div>

    <div class="row">
        <div class="col-xl-5 mb-5">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-header">
                    <div class="col mr-2">
                        <div class="text-md font-weight-bold text-primary text-uppercase mb-1">
                            {% trans %}dashboard.scenario.creation_etape2.parametres{% endtrans %}
                        </div>
                    </div>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="row no-gutters align-items-center">
                        <div class="mb-0 text-gray-800 w-100">
                            <div id="scenario_execution_parametres_{{ scenario.id }}">

                                <div id="loader_{{ scenario.id }}" class="d-none">
                                    <div class="col-md-12">
                                        <h3>
                                            <center>
                                                <i class="fa fa-spinner fa-spin fa-lg"></i>
                                                {% trans %}dashboard.scenario.creation_etape2.chargement{% endtrans %}
                                            </center>
                                        </h3>
                                    </div>
                                </div>
                                <span id="scenario_execution_parametres_form_{{ scenario.id }}" class="d-none">
                                    {% trans %}dashboard.scenario.creation_etape2.aucun_parametre{% endtrans %}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-7 mb-5">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-header">
                    <div class="col mr-2">
                        <div class="text-md font-weight-bold text-info text-uppercase mb-1">
                            Readme
                        </div>
                    </div>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="row no-gutters align-items-center">
                        <div class="mb-0 text-gray-800 w-100 overflow">
                            <div class="container">
                                <div class="row">
                                    <span id="scenario_readme"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <div id="data-parameters" data-parameters="{{ scenario.parametres|json_encode() }}">    
{% endblock %}

{% block javascript %}
    <script>

        function sanitize(string) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#x27;',
                "/": '&#x2F;',
            };
            const reg = /[&<>"'/]/ig;
            return string.replace(reg, (match) => (map[match]));
        }

        let scenarioId = "{{ scenario.id }}";
        let metascenarioId = "{{ scenario.metascenario.id }}";
        let tagHash = "{{ tag.hash }}";
        let datasetHash = "{{ dataset.hash }}";
        let jsonString = $('#data-parameters').data('parameters');
        let selectedParameters = JSON.parse(JSON.stringify(jsonString));
        $("#scenario_execution_parametres_" + scenarioId).removeClass("d-none");
        $("#scenario_execution_parametres_" + scenarioId).addClass("d-block");

        $.ajax({
            url: window.location.origin + "/dashboard/metascenario/ajax/parameters/{{ tag.hash }}",
            method: "GET",
            dataType: "json",
            beforeSend: function () {
                $("#loader_" + scenarioId).removeClass("d-none");
                $("#loader_" + scenarioId).addClass("d-block");
            },
            complete: function () {
                $("#scenario_execution_validation_etape2_" + scenarioId).removeClass("d-none");
                $("#scenario_execution_validation_etape2_" + scenarioId).addClass("d-block");
                $("#loader_" + scenarioId).removeClass("d-block");
                $("#loader_" + scenarioId).addClass("d-none");
                $("#scenario_execution_parametres_form_" + scenarioId).removeClass("d-none");
            },
            success: function (listParams) {

                let readme = listParams.readme || "";
                let md = window.markdownit();
                $("#scenario_readme").html(md.render(readme));
                let txt = "";
                {# If we have switchable algorithm go to the switchable algorithm configuration page #}
                if( listParams.switchable_algorithms.length > 0 ) {
                    txt += `<form method="post" action="{{ path("dashboard_scenario_edit_prepare_algorithm") }}">`;
                }
                else {
                    txt += `<form method="post" action="{{ path("dashboard_scenario_scenario_manage") }}">`;
                }

                /*txt += `<form method="post" action="{{ path("dashboard_scenario_scenario_manage") }}">`;
                txt += `<input type="hidden" name="tag_hash" value="${tagHash}"/>`;
                txt += `<input type="hidden" name="dataset_hash" value="${datasetHash}"/>`;
                txt += `<input type="hidden" name="metascenario_id" value="${metascenarioId}"/>`;
                txt += `<input type="hidden" name="scenario_id" value="${scenarioId}"/>`;*/
                
                for (param in listParams.parameters) {

                    let defaultValue = selectedParameters[listParams.parameters[param].name] || "";
                    let type = listParams.parameters[param].type;
                    let name = sanitize(listParams.parameters[param].name);
                    let help = sanitize(listParams.parameters[param].description);
                    let choices = listParams.parameters[param].choices;

                    txt += `
                        <div class="form-group">
                            <label for="${name}_${scenarioId}"><strong> ${name} </strong></label>
                            <footer class="blockquote-footer">${help}</footer>
                        </div>
                    `;

                    switch (type) {

                        case 'int':
                            txt += `
                                  <input type="number"
                                    class="form-control"
                                    name="${name}"
                                    aria-describedby="${param}_${scenarioId}Help"
                                    placeholder="${name}"
                                    value="${defaultValue}">
                            `;                            
                            break;
                        case 'float':
                            txt += `
                                  <input type="number"
                                    step = "any"
                                    class="form-control"
                                    name="${name}"
                                    aria-describedby="${param}_${scenarioId}Help"
                                    placeholder="${name}"
                                    value="${defaultValue}">
                            `;
                            break;
                        case 'string':
                            txt += `
                                  <input type="text"
                                    class="form-control"
                                    name="${name}"
                                    aria-describedby="${param}_${scenarioId}Help"
                                    placeholder="${name}"
                                    value="${defaultValue}">
                            `;
                            break;
                        case 'bool':
                            let checked = "";
                            if(defaultValue && defaultValue !== "false") {
                                checked = "checked";
                            }
                            txt += `                                  
                                  <input type="hidden" value="false" name="${name}">
                                  <input type="checkbox"
                                    class="form-control"
                                    name="${name}"
                                    value="true"
                                    aria-describedby="${param}_${scenarioId}Help"
                                    placeholder="${name}"
                                    ${checked}
                                    >
                            `;
                            break;
                        case 'choices':

                            txt += `<select name="${name}" class="form-control">`;
                            for (choice in choices) {
                                let selected = (choices[choice] ===  defaultValue) ? 'selected' : '';
                                txt += `<option value="${choices[choice]}" ${selected}>${choices[choice]}</option>`;
                            }
                            txt += `</select>`;
                            break;
                        default:
                    }
                    txt += `<hr />`;
                }

                {# If we have switchable algorithm go to the switchable algorithm configuration page #}
                if( listParams.switchable_algorithms.length > 0 ) {
                    txt += `<button type="submit" class="btn btn-primary btn-block">Switchable algorithm</button>`;
                }
                else {
                    txt += `<button type="submit" class="btn btn-primary btn-block" name="create_button_no_algo" value="create">{% trans %}dashboard.scenario.creation_etape2.creer_scenario{% endtrans %}</button>`;                    
                }                               
                txt += `</form>`;
                $("#scenario_execution_parametres_form_" + scenarioId).html(txt);
            }
        })
</script>

{% endblock %}
