{% extends "dashboard/base/layout.html.twig" %}
{% block title %} Indicateurs {% endblock %}

{% block content %}

    <div class="breadcrumb d-flex justify-content-between align-items-center">
        <div class="d-flex">
            <i class="fas fa-chart-line fa-2x sidebar-brand-icon"></i> 
            <span class="text-monospace sidebar-brand-text ml-4 mt-1"> Administration des indicateurs</span>
        </div>
        <a href="{{ path('dashboard_output_new') }}" class="btn btn-sm btn-primary">
            <i class="fas fa-plus"></i> 
            Ajouter un indicateur
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered dt-basic" id="table_indicateurs" width="98%" cellspacing="0">
            <thead>
                <tr>
                    <th scope="col">Titre</th>
                    <th scope="col">Scénarios</th>
                    <th scope="col">Date de création</th>
                    <th scope="col">Dernière modification</th>
                    <th scope="col">&nbsp;</th>
                </tr>
            </thead>
            <tbody>
                {% for output in outputs %}
                    <tr>
                        <td class="{{ not output.isActive ? 'table-warning' : ''}}">{{ output.name }}</td>
                        <td class="{{ not output.isActive ? 'table-warning' : ''}}">
                            <em>TODO : <br />Liste des scénarios qui utilisent l'algorithme</em>
                        </td>
                        <td class="{{ not output.isActive ? 'table-warning' : ''}}">
                            {% if output.createdBy is not null and output.createdAt is not null%}
                                {{ output.createdAt | date('d-m-Y H:i:s') }}
                                <br /><i>({{ output.createdBy }})</i>
                            {% else %}
                                <i>non défini</i>
                            {% endif %}
                        </td>
                        <td class="{{ not output.isActive ? 'table-warning' : ''}}">
                            {% if output.updatedBy is not null and output.updatedAt is not null%}
                                {{ output.updatedAt | date('d-m-Y H:i:s') }}
                                <br /><i>({{ output.updatedBy }})</i>
                            {% else %}
                                <i>non défini</i>
                            {% endif %}
                        </td>                        
                        <td>
                            <form method="post" class="form-inline" action="{{ path('dashboard_output_delete', {'id': output.id}) }}">
                                <input type="hidden" name="_method" value="DELETE">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ output.id) }}">
                                {%  if output.isActive %}
                                    <a href="{{ path("dashboard_output_toggle_visible", {'id': output.id}) }}" class="btn btn-danger btn-sm">
                                        <i class="fas fa-eye-slash"></i> Masquer
                                    </a> 
                                {% else %}
                                    <a href="{{ path("dashboard_output_toggle_visible", {'id': output.id}) }}" class="btn btn-success btn-sm">
                                        <i class="fas fa-eye"></i> Afficher
                                    </a> 
                                {% endif %} 
                                <a class="btn btn-outline-primary btn-sm ml-2" href="{{ path('dashboard_output_edit', {'id': output.id}) }}">
                                    <i class="fa fa-edit"></i> Modifier 
                                </a>  
                                <button type="submit" class="btn btn-outline-danger btn-sm ml-2">
                                    <i class="fas fa-times"> </i> Supprimer 
                                </button>
                                </a>
                            </form>                                

                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4"><em>Aucun news</em></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
