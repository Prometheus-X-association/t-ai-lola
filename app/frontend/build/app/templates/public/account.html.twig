{% extends "public/base/layout.html.twig" %}

{% block content %}
    <div class="login-wrap" id="login-wrap">
        <div class="login-html" style="min-height:650px;">
            <h2>Lola</h2>
            <blockquote class="smallcaps">Laboratoire Ouvert en Learning Analytics</blockquote>

            <div class="login-form">
                <div class="for-account">
                    {% for flashError in app.flashes('verify_email_error') %}
                        <div class="alert alert-danger" role="alert">{{ flashError }}</div>
                    {% endfor %}
                    {{ form_start(form) }}

                    <div class="group">
                        <label for="email" class="label">Email</label>
                        {{ form_widget(form.email, { 'attr': {'class': 'input'} }) }}
                        <div class="form-error">
                            {{ form_errors(form.email) }}
                        </div>
                    </div>
                    <div class="group">
                        <label for="firstname" class="label">Firstname</label>
                        {{ form_widget(form.firstname, { 'attr': {'class': 'input'} }) }}
                        <div class="form-error">
                            {{ form_errors(form.firstname) }}
                        </div>
                    </div>
                    <div class="group">
                        <label for="lastname" class="label">Lastname</label>
                        {{ form_widget(form.lastname, { 'attr': {'class': 'input'} }) }}
                        <div class="form-error">
                            {{ form_errors(form.lastname) }}
                        </div>
                    </div>
                    <div class="group">
                        <label for="password" class="label">Password</label>
                        {{ form_widget(form.plainPassword, { 'attr': {'class': 'input'} }) }}
                        <div class="form-error">
                            {{ form_errors(form.plainPassword) }}
                        </div>
                    </div>

                    <div class="row pb-2 pt-2 ml-1 mr-1 group">
                        <div class="col-md-8">
                            <a href="#" id="link_terms" class="label" data-toggle="modal" data-target="#terms">Consulter les conditions d'utilisation</a>
                            <hr>
                            {{ form_widget(form.agreeTerms, {label: 'Accepter les conditions'}) }}
                            <div class="form-error">
                                {{ form_errors(form.agreeTerms) }}
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="formHasError" value="{{ formHasError ?? '0' }}">

                    <button type="submit" class="btn btn-outline-success btn-lg btn-block mt-4">Enregistrer</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" tabindex="-1" role="dialog" id="terms">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content text-dark font-weight-light">
                <div class="modal-header">
                    <h4 class="modal-title">
                        Conditions générales d'utilisation du service
                    </h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">   
                    {{ termsOfUse.description | raw }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}