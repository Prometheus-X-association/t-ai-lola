{% extends "public/base/layout.html.twig" %}

{% block content %}
    <div class="row">
        <div class="col-md-12">
            <hr>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <h3 class="pb-4 mb-4 font-italic border-bottom">
                Inscription au service
            </h3>

            <div class="col-md-12">
                {% for flashError in app.flashes('verify_email_error') %}
                    <div class="alert alert-danger" role="alert">{{ flashError }}</div>
                {% endfor %}
                {{ form_start(form) }}
                {{ form_row(form.email) }}
                {{ form_row(form.firstname) }}
                {{ form_row(form.lastname) }}                
                {{ form_row(form.plainPassword, {label: 'Mot de passe'}) }}

                <div class="row border bg-light pb-2 pt-2 ml-1 mr-1">
                    <div class="col-md-8">
                        {{ form_label(form.agreeTerms) }}
                        {{ form_widget(form.agreeTerms) }}
                        <div class="form-error">
                            {{ form_errors(form.agreeTerms) }}
                        </div>
                        <a href="#" id="link_terms" data-toggle="modal" data-target="#terms">Consulter</a>
                    </div>
                    <div class="col-md-4 text-right">
                        {{ form_row(form.captcha) }}
                    </div>
                </div>

                <button type="submit" class="btn btn-outline-success btn-lg btn-block mt-4">Register</button>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="col-md-4">
            {{ include("public/base/right_menu.html.twig") }}
        </div>
    </div>

    <div class="modal fade" tabindex="-1" role="dialog" id="terms">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">
                        Conditions générales d'utilisation du service
                    </h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">   
                    {{ termsOfUse.description | raw }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>         


{% endblock %}


{% block javascript %}
    <!-- jQuery -->
    <script src="{{ asset('node_modules/jquery/dist/jquery.min.js') }}"></script>

    <!-- Popper.js -->
    <script src="{{ asset('node_modules/popper.js/dist/umd/popper.min.js') }}"></script>

    <!-- Bootstrap -->
    <script src="{{ asset('node_modules/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>

    <!-- pwstrength -->
    <script src="{{ asset('node_modules/pwstrength-bootstrap/dist/pwstrength-bootstrap.min.js') }}"></script>

    <!-- lola_public -->
    <script src="{{ asset('js/lola_public.js') }}"></script>

{% endblock %}