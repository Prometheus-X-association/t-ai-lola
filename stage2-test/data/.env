# The ROOT_DIR environment variable must be set to the directory holding this file.
# NB: it will be automatically defined if the .env file is created by the Makefile
#     using this file as a starter.

# Use 'always' in production
RESTART_SERVICES=on-failure


# Project name
COMPOSE_PROJECT_NAME=stage2
COMPOSE_TRAX_FILE=./docker-compose.yml

# Timezone definition
TZ=Europe/Paris

# Listen to localhost only if an nginx proxy is in place
LISTEN_ITF=0.0.0.0

# PORT MAPPING : must be the same as in .env.trax
PORT_MYSQL=3306
PORT_PHPMYADMIN=8080
PORT_TRAX_HTTP=80
PORT_TRAX_HTTPS=443


#database conf : must be the same as in .env.trax
