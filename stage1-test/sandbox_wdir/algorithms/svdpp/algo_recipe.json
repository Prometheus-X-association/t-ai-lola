{
    "name": "SVDpp",
    "description": "SVDpp algorithm to build model for recommendation",
    "command": "svd_train.py --parameters {{ n_factors }} {{ n_epochs }} {{ init_mean }} {{ init_std_dev }} {{ lr_all }} {{ reg_all }} None None None None None None None None None None None --input {{ INPUT_DATA }} --model {{ OUTPUT_DATA }}",
    "harbor_url": "local execution",
    "parameters": [
        {
            "name": "input data file",
            "description": "input data file",
            "variable_name": "INPUT_DATA",
            "type": "input_file_1",
            "editable": false
        },
        {
            "name": "output data file",
            "description": "output data file",
            "variable_name": "OUTPUT_DATA",
            "type": "output_file_1",
            "editable": false
        },
        {
            "name": "n factors",
            "description": "n factors",
            "variable_name": "n_factors",
            "type": "float",
            "editable": true,
            "default": "20"
        },
        {
            "name": "n epochs",
            "description": "n epochs",
            "variable_name": "n_epochs",
            "type": "float",
            "editable": true,
            "default": "20"
        },
        {
            "name": "init mean",
            "description": "init mean",
            "variable_name": "init_mean",
            "type": "float",
            "editable": true,
            "default": "0"
        },
        {
            "name": "init std dev",
            "description": "init std dev",
            "variable_name": "init_std_dev",
            "type": "float",
            "editable": true,
            "default": "0.1"
        },
        {
            "name": "lr_all",
            "description": "lr all",
            "variable_name": "lr_all",
            "type": "float",
            "editable": true,
            "default": "0.007"
        },
        {
            "name": "reg_all",
            "description": "reg all",
            "variable_name": "reg_all",
            "type": "float",
            "editable": true,
            "default": "0.02"
        }
    ]
}
